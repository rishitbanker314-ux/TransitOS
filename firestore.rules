rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Role Checks
    function isAuthenticated() {
      return request.auth != null;
    }

    // Open all collections for authenticated users (including seeding)
    // Vehicles & registrations open for demo
    match /vehicles/{vehicleId} {
      allow read, write: if true;
    }

    match /vehicle_registrations/{regId} {
      allow read, write: if true;
    }

    // All other collections open for authenticated users + public write for seed
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
