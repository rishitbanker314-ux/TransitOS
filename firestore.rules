rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Role Checks
    function isAuthenticated() {
      return request.auth != null;
    }

    // Since we don't have roles implemented yet or auth working smoothly during this phase, 
    // we'll allow authenticated reads, and writes to vehicles for demo purposes.
    // In production, this should be scoped by organization and role.
    
    match /vehicles/{vehicleId} {
      allow read: if true; // allow public read for now to test the UI without auth
      allow write: if true; // allow public write for now to test the UI without auth
    }

    match /vehicle_registrations/{regId} {
      allow read: if true;
      allow write: if true;
    }

    // Other matches omitted or restricted
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}

