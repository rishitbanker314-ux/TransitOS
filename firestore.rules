rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core Role Checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    
    function isDispatcher() {
      return isAuthenticated() && (request.auth.token.role == 'dispatcher' || request.auth.token.role == 'admin');
    }
    
    function isDriver() {
      return isAuthenticated() && request.auth.token.role == 'driver';
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && request.auth.token.orgId == orgId;
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId) || isAdmin();
      allow write: if isAdmin();
      
      // Vehicles Sub-Collection
      match /vehicles/{vehicleId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && isAdmin();
        allow update: if isOrgMember(orgId) && isDispatcher();
        allow delete: if false; // Soft deletes only
      }
      
      // Trips Sub-Collection
      match /trips/{tripId} {
        allow read: if isOrgMember(orgId);
        allow create, update: if isOrgMember(orgId) && (isDispatcher() || isDriver());
        allow delete: if false;
      }
    }
    
    // Aggregated Analytics
    match /analytics/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions can write analytics
    }
  }
}
